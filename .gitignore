# ============================================================
# .gitignore — DX License Manager
# ============================================================

# --- Secrets y entornos ---
infra/.env.beta
infra/.env.prod
.env
.env.*
!.env.beta.example
!.env.prod.example

# --- Obsidian (vault local, nunca en Git) ---
obsidian/

# --- Agente (carpeta completa — local only, nunca en Git) ---
.agent/

# --- Laravel ---
/vendor
/public/storage
/public/hot
/storage/*.key
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*
.phpunit.result.cache

# --- Storage de licencias ---
storage/

# --- Docker ---
infra/.env.beta
infra/.env.prod

# --- Sistema operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDEs ---
.idea/
.vscode/
*.suo
*.user

# --- Backups temporales y tareas ---
backup_pre_normalization.sql
task.md
management/task.md

# --- Carpetas excluidas por el usuario ---
X__Carpeta Temporal/