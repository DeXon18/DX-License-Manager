###############################################################################
# CONFIGURACIÓN GENERAL DE LA APLICACIÓN
###############################################################################
APP_NAME='DX License Manager Beta'
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://beta.dxpro.es
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

###############################################################################
# CONFIGURACIÓN DE LOGS
###############################################################################
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

###############################################################################
# BASE DE DATOS (MARIADB)
###############################################################################
# Configuración para Laravel
DB_CONNECTION=mysql
DB_HOST=mariadb-beta
DB_PORT=3306
DB_DATABASE=dxportal_beta
DB_USERNAME=dxportal
DB_PASSWORD=

# Configuración para el Contenedor Docker
MYSQL_DATABASE=dxportal_beta
MYSQL_USER=dxportal
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

###############################################################################
# SERVICIOS DE CACHÉ Y COLAS (REDIS)
###############################################################################
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis-beta
REDIS_PASSWORD=null
REDIS_PORT=6379

# Fallback para servicios no usados
MEMCACHED_HOST=127.0.0.1

###############################################################################
# CONFIGURACIÓN DE EMAIL (SMTP MAILTRAP PRODUCTION)
###############################################################################
MAIL_DRIVER=smtp
MAIL_HOST=send.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=api
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@dxpro.es
MAIL_FROM_NAME='Soporte AYS'

###############################################################################
# MOTORES DE INTELIGENCIA ARTIFICIAL (API KEYS)
###############################################################################
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

###############################################################################
# NOTIFICACIONES EXTERNAS (TELEGRAM)
###############################################################################
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

###############################################################################
# SERVICIOS DE TERCEROS (AWS / PUSHER) - [OPCIONAL]
###############################################################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

###############################################################################
# CONFIGURACIÓN DE FRONTEND (VITE)
###############################################################################
VITE_APP_NAME='DX License Manager Beta'