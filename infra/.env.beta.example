# Aplicación
APP_ENV=local
APP_KEY=
APP_URL=https://beta.dxpro.es
APP_DEBUG=true

# Base de Datos
DB_CONNECTION=mysql
DB_HOST=mariadb-beta
DB_PORT=3306
DB_DATABASE=dxportal_beta
DB_USERNAME=dxportal
DB_PASSWORD=

# MariaDB Docker
MYSQL_DATABASE=dxportal_beta
MYSQL_USER=dxportal
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Redis
REDIS_HOST=redis-beta
REDIS_PORT=6379
REDIS_PASSWORD=null

# Cache y Colas
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Email (SMTP Mailtrap)
MAIL_DRIVER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@dxpro.es
MAIL_FROM_NAME="Soporte AYS"

# IA
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Notificaciones
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=